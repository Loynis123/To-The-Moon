# Copy to .env and adjust. .env is git-ignored.
PORT=3001

# MUST be a long random string in production — the server refuses to boot in
# production without it. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Database (libSQL / Turso). Leave BOTH unset for local dev — the server falls
# back to a local file at server/data/cyber.db.
# In production point these at a Turso database:
#   DATABASE_URL=libsql://<your-db>-<org>.turso.io
#   DATABASE_AUTH_TOKEN=<token from `turso db tokens create <your-db>`>
DATABASE_URL=
DATABASE_AUTH_TOKEN=
